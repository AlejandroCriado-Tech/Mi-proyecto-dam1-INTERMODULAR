<?xml version="1.0" encoding="UTF-8"?>
<!--
    datos-incorrecto.xml — XML con errores INTENCIONADOS
    Módulo: Lenguajes de Marcas y Sistemas de Gestión de Información (0373)
    Autor: Alejandro Criado Pérez

    Este archivo demuestra que el esquema.xsd detecta correctamente
    los errores cuando el XML no cumple las restricciones definidas.

    ERRORES INTENCIONADOS:
    1. Email sin @ → falla tipoEmail (pattern)
    2. Importe negativo → falla tipoImporte (minExclusive value="0")
    3. Mes = 15 → falla tipoMes (maxInclusive value="12")
    4. Año = 1999 → falla tipoAnio (minInclusive value="2020")
    5. Nombre vacío → falla tipoNombre (minLength value="2")
-->
<gastosapp xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:noNamespaceSchemaLocation="esquema.xsd">

    <usuario>
        <id>1</id>
        <nombre>A</nombre> <!-- ❌ ERROR 5: nombre de 1 carácter, mínimo 2 -->
        <email>alejandroSINarroba.com</email> <!-- ❌ ERROR 1: email sin @ -->
        <fecha_registro>2026-01-10</fecha_registro>
    </usuario>

    <categorias>
        <categoria>
            <id>1</id>
            <nombre>Alimentación</nombre>
            <descripcion>Supermercado y restaurantes</descripcion>
        </categoria>
    </categorias>

    <gastos>
        <gasto>
            <id>1</id>
            <id_categoria>1</id_categoria>
            <categoria>Alimentación</categoria>
            <importe>-25.00</importe> <!-- ❌ ERROR 2: importe negativo, debe ser mayor que 0 -->
            <descripcion>Compra supermercado</descripcion>
            <fecha>2026-01-05</fecha>
        </gasto>
    </gastos>

    <presupuestos>
        <presupuesto>
            <id>1</id>
            <categoria>Global</categoria>
            <limite>1200.00</limite>
            <mes>15</mes>   <!-- ❌ ERROR 3: mes 15 no existe, máximo 12 -->
            <anio>1999</anio> <!-- ❌ ERROR 4: año 1999, mínimo permitido 2020 -->
        </presupuesto>
    </presupuestos>

</gastosapp>
