<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<!--
    main.fxml — Pantalla principal de GastosApp
    Controlador: MainController.java

    Los fx:id deben coincidir EXACTAMENTE con los @FXML del controlador.
    El fx:controller indica qué clase Java controla esta pantalla.

    Autor: Alejandro Criado Pérez
-->
<VBox xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.alejandro.gastosapp.controller.MainController"
      alignment="CENTER"
      spacing="20"
      style="-fx-background-color: #f4f4f4;">

    <padding>
        <Insets top="60" right="80" bottom="60" left="80"/>
    </padding>

    <!-- Título de la app -->
    <Label text="💰 GastosApp"
           style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

    <Label text="Gestiona tus gastos personales"
           style="-fx-font-size: 14px; -fx-text-fill: #7f8c8d;"/>

    <!-- Separador visual -->
    <Region prefHeight="20"/>

    <!-- Botón Gastos -->
    <Button fx:id="btnGastos"
            text="📋  Mis Gastos"
            onAction="#abrirGastos"
            prefWidth="250"
            prefHeight="50"
            style="-fx-background-color: #3498db; -fx-text-fill: white;
                   -fx-font-size: 16px; -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

    <!-- Botón Presupuestos -->
    <Button fx:id="btnPresupuestos"
            text="🎯  Presupuestos"
            onAction="#abrirPresupuestos"
            prefWidth="250"
            prefHeight="50"
            style="-fx-background-color: #2ecc71; -fx-text-fill: white;
                   -fx-font-size: 16px; -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

    <!-- Separador visual -->
    <Region prefHeight="20"/>

    <!-- Botón Salir -->
    <Button fx:id="btnSalir"
            text="❌  Salir"
            onAction="#salir"
            prefWidth="150"
            prefHeight="40"
            style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                   -fx-font-size: 14px; -fx-background-radius: 8;
                   -fx-cursor: hand;"/>

    <!-- Pie de página -->
    <Region prefHeight="20"/>
    <Label text="Alejandro Criado Pérez — DAM 1º — 2026"
           style="-fx-font-size: 11px; -fx-text-fill: #bdc3c7;"/>

</VBox>
